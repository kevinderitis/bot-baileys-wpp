# --- WhatsApp ---
SESSION_PATH=./sessions

# --- MongoDB ---
MONGODB_URI=mongodb://localhost:27017/bot-whatsapp-agencia

# --- Groq AI ---
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_SUMMARY_MODEL=llama-3.1-8b-instant
GROQ_MAX_TOKENS=1024
GROQ_TEMPERATURE=0.7

# --- AI Context ---
AI_MAX_CONTEXT_MESSAGES=20
AI_SUMMARIZE_AFTER=40
AI_KEEP_AFTER_SUMMARY=20

# --- Server ---
PORT=3000

# --- Bot ---
MIN_DELAY_SECONDS=3
MAX_DELAY_SECONDS=45
TYPING_SPEED_CPS=4
